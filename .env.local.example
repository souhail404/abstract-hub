# ─── Database (Supabase) ─────────────────────────────────────────────────────
# From: Supabase → Project Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# From: Supabase → Project Settings → Database → Connection string → URI (direct)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── Supabase Storage (for banner image uploads) ─────────────────────────────
# From: Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://zweonbmonifiglzahkgi.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="sb_publishable_1-PWb8pRpRgSLSQG6PNe9g_aCY6E2YI"  # Service role key (keep secret!)

# ─── Auth.js ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32  (or any random 32+ char string)
AUTH_SECRET="your-random-secret-here"

# ─── Twitter / X OAuth ───────────────────────────────────────────────────────
# From: developer.twitter.com → Projects → Your App → Keys and tokens
# Callback URL to add in Twitter app: https://yourdomain.com/api/auth/callback/twitter
TWITTER_CLIENT_ID="your-twitter-client-id"
TWITTER_CLIENT_SECRET="your-twitter-client-secret"

# ─── Google OAuth ────────────────────────────────────────────────────────────
# From: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
# Callback URL to add in Google: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── App URL ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"   # change to your production domain when deploying
